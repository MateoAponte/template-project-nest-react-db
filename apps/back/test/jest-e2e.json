{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../",
  "testMatch": ["**/test/**/*.e2e.spec.ts"],
  "transform": { "^.+\\.(t|j)s$": "ts-jest" },
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1",
    "^config/(.*)$": "<rootDir>/config/$1",
    "^test/(.*)$": "<rootDir>/test/$1"
  }
}
